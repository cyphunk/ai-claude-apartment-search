# Copy to .env for local runs. On Railway, set these in the service Variables tab instead.
HOWOGE_TG_TOKEN=123456:your-botfather-token
HOWOGE_TG_CHAT=987654321
# Optional, only needed if you run locally without a volume:
# SEEN_PATH=seen_listings.json
# Active polling window (Europe/Berlin, DST-aware). Defaults: 05:00–23:00, Mon–Fri.
# The current government sources don't publish on weekends/overnight; relax these
# if commercial sources are added. Set ACTIVE_HOURS_ENABLED=0 to poll 24/7.
# ACTIVE_HOURS_ENABLED=1
# ACTIVE_START_HOUR=5
# ACTIVE_END_HOUR=23
# ACTIVE_WEEKDAYS=0,1,2,3,4
